# Copy this file to .env and fill in the values.
# Do NOT commit the real .env file.

# --- Application ---
NODE_ENV=development
PORT=3000
# Host port that maps to nginx (compose only).
HTTP_PORT=8080

# --- Session ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# --- MySQL ---
# In docker compose, DB_HOST is overridden to `db`. Set localhost only for
# host-machine `npm start` against a manually-run MySQL.
DB_HOST=localhost
DB_PORT=3306
DB_USER=banker
DB_PASSWORD=banker
DB_NAME=bank
DB_CONNECTION_LIMIT=10
# Compose-only: root password used by the MySQL container itself.
DB_ROOT_PASSWORD=rootpass
