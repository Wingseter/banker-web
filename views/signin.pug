extends layout

block content
  section.app-page.app-page--tight
    .container
      .app-card
        .app-page-eyebrow 명지은행 · Myongji Bank
        h1.app-page-title(style='font-size:24px;margin-bottom:var(--sp-5)') 로그인
        form.app-form(action='/signin', method='POST')
          +csrf
          .app-field
            label.app-label(for='email') 이메일
            input.app-input#email(
              type='email', name='email', placeholder='you@example.com',
              required, autofocus, autocomplete='username'
            )
          .app-field
            label.app-label(for='password') 비밀번호
            input.app-input#password(
              type='password', name='password',
              required, autocomplete='current-password'
            )
          button.app-btn.app-btn-primary.app-btn-block.app-btn-lg(type='submit') 로그인
          .app-actions(style='justify-content:center;font-size:13px;color:var(--app-text-muted);margin-top:var(--sp-2)')
            a(href='/users/new', style='color:var(--app-brand);text-decoration:none') 회원가입
            span ·
            a(href='/reset-password', style='color:var(--app-text-muted);text-decoration:none') 비밀번호 찾기
