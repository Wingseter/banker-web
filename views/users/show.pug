extends ../layout

block content
  section.app-page.app-page--narrow
    .container
      .app-page-head
        div
          .app-page-eyebrow 사용자 정보
          h1.app-page-title= `${user.name} 님`
        .app-page-meta
          a.app-btn.app-btn-secondary.app-btn-sm(href='/users') 목록
          if currentUser && currentUser.id == user.id
            a.app-btn.app-btn-primary.app-btn-sm(href=`/users/${user.id}/edit`) 수정

      .app-card
        dl.app-stat-list
          .app-stat-row
            dt.app-stat-label 이름
            dd.app-stat-value= user.name
          .app-stat-row
            dt.app-stat-label 이메일
            dd.app-stat-value= user.email
          .app-stat-row
            dt.app-stat-label 사용자 ID
            dd.app-stat-value.app-stat-value--mono= user.id
          .app-stat-row
            dt.app-stat-label 주소
            dd.app-stat-value= user.address
          .app-stat-row
            dt.app-stat-label 전화번호
            dd.app-stat-value.app-stat-value--mono= user.phone
          .app-stat-row
            dt.app-stat-label 직업
            dd.app-stat-value= user.job || '—'

      if currentUser && currentUser.id != user.id
        .app-card
          .app-actions.app-actions--end
            +deleteForm(`/users/${user.id}`, '계정 삭제').app-btn.app-btn-danger.app-btn-sm
