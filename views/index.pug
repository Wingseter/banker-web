extends layout

block content
  .landing
    //- ============================================================
    //- JUMBOTRON — campus banner (legacy hero image, restored)
    //- ============================================================
    section.lp-jumbo(aria-label='명지은행 브랜드 이미지')
      .container
        .lp-jumbo-frame
          img.lp-jumbo-img(
            src='/images/bg.jpg',
            alt='명지은행 · Myongji Bank — 학생 핀테크 데모',
            loading='eager',
            decoding='async'
          )
          .lp-jumbo-overlay(aria-hidden='true')
          .lp-jumbo-meta
            .lp-jumbo-badge
              span.lp-jumbo-dot
              | 학생 핀테크 데모 · Demo

    //- ============================================================
    //- HERO
    //- ============================================================
    section.lp-hero
      .container
        .lp-hero-grid
          div
            .lp-eyebrow 학생 핀테크 데모 · v2.0
            h1
              | 통장 하나로
              br
              em 30초 안에 송금까지.
            p.lp-hero-sub 명지은행은 입출금·이체·카드 결제·거래 내역을 한 화면에서 정돈합니다. 회원가입부터 첫 송금까지 평균 28초.
            .lp-btn-group
              if currentUser
                a.lp-btn.lp-btn-primary(href='/accounts')
                  | 내 계좌로 가기
                  span(aria-hidden='true') →
              else
                a.lp-btn.lp-btn-primary(href='/users/new') 무료로 시작하기
                a.lp-btn.lp-btn-secondary(href='/signin') 로그인
            .lp-hero-kpi
              div
                .lp-hero-kpi-num 28
                  small 초
                .lp-hero-kpi-label 가입 → 첫 송금
              div
                .lp-hero-kpi-num 0
                  small 원
                .lp-hero-kpi-label 이체 수수료
              div
                .lp-hero-kpi-num 24
                  small /7
                .lp-hero-kpi-label 모바일·웹 접근

          .lp-hero-mock(aria-hidden='true')
            .lp-mock-top
              div
                .lp-eyebrow 총자산
                .lp-mock-asset.lp-mono
                  span.lp-mock-asset-mark ₩
                  | 12,840,500
              span.lp-money-pos.lp-mono +32,000원
            .lp-mock-spark
              .lp-mock-spark-label 최근 30일
              svg(viewBox='0 0 320 56', preserveAspectRatio='none')
                path(
                  d='M0,38 L20,34 L40,40 L60,30 L80,32 L100,24 L120,28 L140,18 L160,22 L180,12 L200,18 L220,8 L240,16 L260,10 L280,6 L300,12 L320,4',
                  fill='none',
                  stroke='var(--app-brand)',
                  stroke-width='2',
                  stroke-linecap='round',
                  stroke-linejoin='round'
                )
                path(
                  d='M0,38 L20,34 L40,40 L60,30 L80,32 L100,24 L120,28 L140,18 L160,22 L180,12 L200,18 L220,8 L240,16 L260,10 L280,6 L300,12 L320,4 L320,56 L0,56 Z',
                  fill='var(--app-brand)',
                  fill-opacity='0.12'
                )
            .lp-mock-grid
              .lp-mock-card
                .lp-mock-card-num 311-0021-2904
                .lp-mock-card-bal
                  | 8,420,300
                  span.unit 원
                .lp-mock-card-type 일반 통장
              .lp-mock-card
                .lp-mock-card-num 311-0028-1145
                .lp-mock-card-bal
                  | 4,420,200
                  span.unit 원
                .lp-mock-card-type 적금 통장
            .lp-mock-tx
              .lp-mock-tx-row
                span.lp-mock-tx-date 오늘 14:32
                span 스타벅스 명지대점
                span.lp-mock-tx-amt.lp-money-neg −6,500원
              .lp-mock-tx-row
                span.lp-mock-tx-date 오늘 09:12
                span 이수민으로부터
                span.lp-mock-tx-amt.lp-money-pos +32,000원
              .lp-mock-tx-row
                span.lp-mock-tx-date 어제
                span ATM 출금
                span.lp-mock-tx-amt.lp-money-neg −50,000원

    //- ============================================================
    //- STATS STRIP (simulated social proof — student demo)
    //- ============================================================
    section.lp-stats
      .container
        .lp-stats-grid
          div
            .lp-stat-num
              | 12,400
              small +명
              span.lp-stat-up · 누적
            .lp-stat-label 데모 사용자
          div
            .lp-stat-num
              | ₩384
              small 억
            .lp-stat-label 누적 처리 금액
          div
            .lp-stat-num
              | 4.8
              small /5
              span.lp-stat-up · ★
            .lp-stat-label 데모 사용자 평점
          div
            .lp-stat-num
              | 0.18
              small 초
            .lp-stat-label 평균 API 응답
        .lp-stats-disclaimer ※ 모든 수치는 학생 핀테크 데모용 시뮬레이션입니다.

    //- ============================================================
    //- TRUST / REGULATOR BADGES
    //- ============================================================
    section.lp-trust
      .container
        .lp-eyebrow.mb-3 보안 & 규제 (시뮬레이션)
        h2.lp-section-h2(style='font-size:24px;font-weight:600;letter-spacing:-0.02em;margin:8px 0 20px;color:var(--app-text)') 실제 은행처럼 설계된 보안 체계
        .lp-trust-grid
          .lp-trust-card
            .lp-trust-icon 12
            div
              .lp-trust-title bcrypt(12) 해시
              .lp-trust-desc 비밀번호는 평문으로 저장되지 않습니다.
          .lp-trust-card
            .lp-trust-icon C
            div
              .lp-trust-title CSRF 토큰 검증
              .lp-trust-desc 모든 변경 요청에 토큰 기반 위조 방지.
          .lp-trust-card
            .lp-trust-icon S
            div
              .lp-trust-title 세션 쿠키 보호
              .lp-trust-desc httpOnly · sameSite · production에서 secure.
          .lp-trust-card
            .lp-trust-icon TX
            div
              .lp-trust-title 트랜잭션 일관성
              .lp-trust-desc 이체·결제는 SELECT FOR UPDATE + 트랜잭션.

    //- ============================================================
    //- PRODUCT SHOWCASE 1 — 이체
    //- ============================================================
    section.lp-showcase
      .container
        .lp-showcase-grid
          .lp-showcase-copy
            .lp-eyebrow 이체
            h3
              | 받는 계좌·금액·메모만.
              br
              | 송금
              | #[mark 즉시]
              | 잔액에 반영.
            p 다른 은행처럼 영업일 마감 시간을 기다리지 않아요. 송금하는 그 순간 거래 내역과 잔액에 동시에 기록됩니다. 같은 통장 안에서 매번 같은 트랜잭션이 두 계좌에 정확히 떨어지는지 검증되었습니다.
            ul.lp-showcase-list
              li 받는 계좌 ID 빠른 선택(내 통장 자동 표시)
              li 빠른 금액 칩(1만 · 5만 · 10만 · 50만)
              li 송금 후 잔액 미리보기
              li 잘못된 계좌 / 잔액 부족 시 즉시 거부
          .lp-showcase-screen(aria-hidden='true')
            .lp-screen-tab 이체 화면 · 미리보기
            .lp-screen-field
              .lp-screen-field-label 받는 계좌번호
              .lp-screen-field-value 311-0028-1145
            .lp-screen-quick
              span.lp-screen-chip 1만
              span.lp-screen-chip.is-active 5만
              span.lp-screen-chip 10만
              span.lp-screen-chip 50만
            .lp-screen-field
              .lp-screen-field-label 송금 금액
              .lp-screen-field-value.lp-brand ₩ 50,000
            .lp-screen-field
              .lp-screen-field-label 송금 후 잔액
              .lp-screen-field-value 8,370,300원
            .lp-screen-cta 송금 실행

    //- ============================================================
    //- PRODUCT SHOWCASE 2 — 카드
    //- ============================================================
    section.lp-showcase
      .container
        .lp-showcase-grid.lp-reverse
          .lp-showcase-copy
            .lp-eyebrow 카드
            h3
              | 한도와 연결 계좌를 골라
              br
              | #[mark 발급 → 즉시 결제].
            p 카드를 발급하면 결제 한도 안에서 곧장 사용할 수 있어요. 결제 즉시 연결 계좌 잔액이 차감되고, 거래 내역에 가맹점·금액·시각이 함께 남습니다.
            ul.lp-showcase-list
              li 다섯 가지 카드 종류 (명지 사랑·브론즈·골드·블랙·프리미엄 CS)
              li 연결 계좌 자유 선택 / 한도 직접 설정
              li 결제 즉시 잔액 차감 + 내역 기록
              li 잔액 부족 시 결제 자동 거부
          .lp-showcase-screen(aria-hidden='true', style='display:flex;align-items:center;justify-content:center;background:transparent;border:0;box-shadow:none;padding:0')
            .lp-card-tile(style='width:100%;max-width:380px')
              .lp-card-tile-row
                span.lp-card-tile-name 명지은행 PREMIUM
                span.lp-card-tile-brand 명지 BANK
              div(style='display:flex;align-items:center;gap:12px')
                .lp-card-tile-chip
                span.lp-card-tile-name(style='letter-spacing:0.06em') BLACK
              .lp-card-tile-num 1101 ··· ···· 2904
              .lp-card-tile-row
                span.lp-card-tile-meta 한도 ₩2,000,000
                span.lp-card-tile-meta 04 / 28

    //- ============================================================
    //- FEATURE GRID (6 cards)
    //- ============================================================
    section.lp-features
      .container
        .lp-eyebrow 서비스 구성
        h2(style='font-size:28px;font-weight:600;letter-spacing:-0.02em;margin:8px 0 0;color:var(--app-text)') 한 화면에 들어오는 여섯 가지
        .lp-features-grid
          .lp-feature
            .lp-feature-icon ①
            h4 통장 관리
            p 청약·일반·적금·청년 미래 네 종 통장. 잔액·이자율·만기를 한 줄에.
          .lp-feature
            .lp-feature-icon ②
            h4 이체
            p 받는 계좌·금액·메모만. 송금 즉시 잔액·거래 내역 동시 반영.
          .lp-feature
            .lp-feature-icon ③
            h4 카드 발급
            p 한도와 연결 계좌를 골라 발급. 즉시 사용 가능.
          .lp-feature
            .lp-feature-icon ④
            h4 카드 결제
            p 가맹점·금액·시각을 함께 기록. 잔액 자동 차감.
          .lp-feature
            .lp-feature-icon ⑤
            h4 거래 내역
            p 월별·계좌별 필터. 입출금 부호·잔액 누적을 한 줄에.
          .lp-feature
            .lp-feature-icon ⑥
            h4 보안
            p bcrypt·CSRF·세션 쿠키·SELECT FOR UPDATE 트랜잭션.

    //- ============================================================
    //- FAQ
    //- ============================================================
    section.lp-faq
      .container
        .lp-faq-grid
          .lp-faq-head
            .lp-eyebrow 자주 묻는 질문
            h2 시작 전에 한 번 살펴보세요
            p 데모 환경의 동작 방식과 한계를 솔직히 적어두었습니다.
          .lp-faq-list
            details.lp-faq-item(open)
              summary 실제 돈이 오가나요?
              .lp-faq-answer 아니요. 명지은행은 학생 핀테크 데모입니다. 모든 잔액·거래 내역은 시뮬레이션이며, 실제 계좌·카드·결제와 연결되지 않습니다.
            details.lp-faq-item
              summary 어떤 보안 장치가 있나요?
              .lp-faq-answer 비밀번호는 bcrypt(12) 해시로만 저장됩니다. 모든 변경 요청은 CSRF 토큰을 검증하며, 세션 쿠키는 httpOnly·sameSite·production에서 secure가 설정됩니다. 이체·결제는 트랜잭션과 SELECT FOR UPDATE로 일관성을 보장합니다.
            details.lp-faq-item
              summary 카드 발급 후 한도는 어떻게 정하나요?
              .lp-faq-answer 카드 발급 시 직접 한도를 입력하고 연결 계좌를 선택합니다. 결제 시 연결 계좌의 잔액과 카드 한도 모두 확인되어, 둘 중 하나라도 부족하면 결제가 거부됩니다.
            details.lp-faq-item
              summary 데이터는 어디 저장되나요?
              .lp-faq-answer MySQL 8.0 컨테이너에 저장되며, 비밀번호는 평문이 아닌 bcrypt 해시로만 들어갑니다. 서버는 TypeScript + Express + Pug 스택으로 구성되어 있고 GitHub Actions에서 jest 회귀 테스트를 통과한 코드만 배포됩니다.
            details.lp-faq-item
              summary 모바일에서도 잘 동작하나요?
              .lp-faq-answer 네. 360px 폭부터 데스크탑 1280px까지 한 페이지에서 전부 동작하도록 설계되어 있고, 다크 모드는 시스템 설정(`prefers-color-scheme`)을 따라갑니다.

    //- ============================================================
    //- APP DOWNLOAD CTA
    //- ============================================================
    section.lp-app
      .container
        .lp-app-banner
          div
            h2 곧, 모바일 앱에서도.
            p iOS·Android 네이티브 앱은 v3 로드맵에 있습니다. 그때까지는 모바일 브라우저에서 동일한 흐름으로 사용하실 수 있어요.
            .lp-app-badges
              span.lp-app-badge
                span.lp-badge-icon
                div
                  .lp-app-badge-sub Coming soon
                  strong App Store
              span.lp-app-badge
                span.lp-badge-icon ▷
                div
                  .lp-app-badge-sub Coming soon
                  strong Google Play
          .lp-app-side(aria-hidden='true')
            .lp-phone
              .lp-phone-screen
                .lp-phone-row.lp-tall.lp-accent
                .lp-phone-row(style='width:60%')
                .lp-phone-row(style='width:80%')
                .lp-phone-row(style='width:45%')
                .lp-phone-row.lp-tall
                .lp-phone-row(style='width:70%')
                .lp-phone-row(style='width:55%')

    //- ============================================================
    //- DEMO ACCOUNT STRIP (anonymous only)
    //- ============================================================
    if !currentUser
      section.lp-demo
        .container
          .lp-demo-row
            div
              .lp-eyebrow 시연 계정
              .lp-demo-creds
                span.lp-mono demo@banker.local
                span.lp-sep ·
                span.lp-mono password123
            a.lp-btn.lp-btn-secondary(href='/signin')
              | 로그인 화면으로
              span(aria-hidden='true') →
