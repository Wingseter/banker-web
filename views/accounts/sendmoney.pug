extends ../layout

block content
  section.app-page.app-page--tight
    .container
      .app-page-head
        div
          .app-page-eyebrow 계좌 ##{account.id}
          h1.app-page-title 계좌 이체
          p.app-page-subtitle 받는 계좌번호와 금액을 입력하세요.

      .app-card
        form.app-form(action=`/accounts/${account.id}/sendmoney`, method='POST')
          +csrf
          .app-field
            label.app-label(for='to') 받는 계좌번호
            input.app-input#to(type='text', name='to', placeholder='예) 123', inputmode='numeric', required)
          .app-field
            label.app-label(for='money') 금액
            input.app-input.app-input--money#money(type='text', name='money', placeholder='0', inputmode='numeric', required)
            .app-help 단위: 원
          .app-field
            label.app-label(for='content') 내용 (선택)
            input.app-input#content(type='text', name='content', placeholder='예) 월세')
          .app-actions.app-actions--end
            a.app-btn.app-btn-secondary(href=`/accounts/${account.id}`) 취소
            button.app-btn.app-btn-primary(type='submit') 송금하기
