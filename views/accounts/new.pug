extends ../layout

block content
  section.app-page.app-page--tight
    .container
      .app-page-head
        div
          .app-page-eyebrow 계좌 개설
          h1.app-page-title 새 계좌

      .app-card
        form.app-form(action='/accounts', method='POST')
          +csrf
          include _form
          .app-actions.app-actions--end
            a.app-btn.app-btn-secondary(href='/accounts') 취소
            button.app-btn.app-btn-primary(type='submit') 개설하기
