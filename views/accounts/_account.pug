a.app-account-link(href=`/accounts/${account.id}`)
  .app-account
    div
      .app-account-head
        span.app-pill.app-pill--brand= account.type || '일반 통장'
        span.app-account-num · 계좌 ##{account.id}
      .app-account-bal
        span.app-account-bal-num= Number(account.money).toLocaleString('ko-KR')
        span.app-account-bal-currency 원
      .app-account-meta
        span 개설일 #{moment(account.date).format('YYYY-MM-DD')}
        if account.content
          span ·
          span= account.content
    span.app-account-arrow(aria-hidden='true') →
