extends ../layout

block content
  section.app-page.app-page--tight
    .container
      .app-page-head
        div
          .app-page-eyebrow 계좌 ##{account.id}
          h1.app-page-title 입금
          p.app-page-subtitle 입금 금액과 내역을 입력하세요.

      .app-card
        form.app-form(action=`/accounts/${account.id}/input`, method='POST')
          +csrf
          .app-field
            label.app-label(for='money') 금액
            input.app-input.app-input--money#money(type='text', name='money', placeholder='0', inputmode='numeric', required)
            .app-help 단위: 원
          .app-field
            label.app-label(for='content') 내용
            input.app-input#content(type='text', name='content', placeholder='예) 월급')
          .app-actions.app-actions--end
            a.app-btn.app-btn-secondary(href=`/accounts/${account.id}`) 취소
            button.app-btn.app-btn-primary(type='submit') 입금하기
