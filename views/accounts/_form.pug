- var current = (typeof account !== 'undefined' && account && account.type) ? account.type : null;
.app-field
  label.app-label(for='type') 통장 종류
  select.app-select#type(name='type')
    each opt in ['청약 저축 통장', '일반 통장', '적금 통장', '청년 미래 통장']
      option(value=opt, selected=(current === opt))= opt
