extends ../layout

block content
  section.app-page.app-page--tight
    .container
      .app-page-head
        div
          .app-page-eyebrow 카드 신청
          h1.app-page-title 새 카드

      .app-card
        form.app-form(action='/cards', method='POST')
          +csrf
          include _form
          .app-actions.app-actions--end
            a.app-btn.app-btn-secondary(href='/cards') 취소
            button.app-btn.app-btn-primary(type='submit') 신청하기
